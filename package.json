{
  "name": "evertas",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "gen:schema": "node scripts/gen-schema.mjs",
    "gen:types:react": "supabase gen types typescript --db-url \"postgresql://postgres:postgres@127.0.0.1:54322/postgres\" --schema public > src/data/database.types.ts",
    "gen:types:edge": "pnpm exec supabase gen types typescript --local > supabase/functions/_shared/database.types.ts",
    "gen:types": "pnpm gen:types:react && pnpm gen:types:edge",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "reset:db:local": "pnpm supabase db reset --local",
    "apply-migration": "pnpm supabase migration up --local"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@googlemaps/js-api-loader": "^2.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-data-grid": "^9.7.0",
    "@mui/x-date-pickers": "^9.7.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/router-plugin": "^1.132.0",
    "dayjs": "^1.11.21",
    "jwt-decode": "^4.0.0",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.2",
    "react-imask": "^7.6.1",
    "sonner": "^2.0.7",
    "use-places-autocomplete": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@tanstack/router-plugin": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "supabase": "^2.109.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "supabase"
    ]
  }
}